{
  "name": "verifydocs-online",
  "version": "1.0.0",
  "private": true,
  "description": "VerifyDocs online utilities and PDF tool APIs.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "test:pdf-tools": "node scripts/test-pdf-tools.js",
    "security:audit": "npm audit --audit-level=moderate",
    "security:scan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/security-scan.ps1"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "pptxgenjs": "^4.0.1"
  }
}
